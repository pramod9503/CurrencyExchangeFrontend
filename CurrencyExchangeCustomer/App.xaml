<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CurrencyExchangeCustomer"
             x:Class="CurrencyExchangeCustomer.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="ButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="MinimumWidthRequest" Value="100"></Setter>
                <Setter Property="MaximumWidthRequest" Value="150"></Setter>
                <Setter Property="MinimumHeightRequest" Value="30"></Setter>
                <Setter Property="MaximumHeightRequest" Value="30"></Setter>
                <Setter Property="Padding" Value="15,4,15,4"></Setter>
                <Setter Property="BackgroundColor" Value="Teal"></Setter>
                <Setter Property="HorizontalOptions" Value="End"></Setter>
                <Setter Property="CornerRadius" Value="15"></Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
